// Folder-specific settings
//
// For a full list of overridable settings, and general information on folder-specific settings,
// see the documentation: https://zed.dev/docs/configuring-zed#settings-files
{
  "lsp": {
    "eslint": {
      "settings": {
        "workingDirectory": {
          "mode": "auto"
        },
        "validate": [
          "javascript",
          "javascriptreact",
          "typescript",
          "typescriptreact",
          "astro"
        ]
      }
    }
  },
  "languages": {
    "JavaScript": {
      "format_on_save": "on",
      "formatter": [
        {
          "code_action": "source.fixAll.eslint"
        },
        {
          "external": {
            "command": "pnpm",
            "arguments": [
              "exec",
              "prettier",
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        }
      ]
    },
    "TypeScript": {
      "format_on_save": "on",
      "formatter": [
        {
          "code_action": "source.fixAll.eslint"
        },
        {
          "external": {
            "command": "pnpm",
            "arguments": [
              "exec",
              "prettier",
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        }
      ]
    },
    "TSX": {
      "format_on_save": "on",
      "formatter": [
        {
          "code_action": "source.fixAll.eslint"
        },
        {
          "external": {
            "command": "pnpm",
            "arguments": [
              "exec",
              "prettier",
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        }
      ]
    }
  }
}
